{
  "name": "project-nest",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:generate": "npm run db:generate -w packages/backend",
    "db:push": "npm run db:push -w packages/backend",
    "syncDb": "npm run syncDb -w packages/backend",
    "build:shared": "tsc -p packages/shared",
    "build:frontend": "npm run build -w packages/frontend",
    "build:backend": "npm run build -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:all": "npm run dev -w packages/frontend && npm run dev -w packages/backend",
    "lint:frontend": "npm run lint -w packages/frontend",
    "tsc:frontend": "npm run tsc -w packages/frontend",
    "tsc:backend": "npm run tsc -w packages/backend"
  },
  "devDependencies": {
    "eslint": "^10.0.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "pg": "^8.20.0",
    "react-error-boundary": "^6.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "zod": "^4.3.6"
  }
}
