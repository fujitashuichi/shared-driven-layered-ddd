{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push --config ./src/prisma.config.ts",
    "syncDb": "npm run db:generate && npm run db:push",
    "dev": "npm run syncDb && tsx watch --env-file=.env.development src/index.ts",
    "start": "tsx src/index.ts",
    "build": "npm run syncDb && tsc",
    "test": "tsx ./src/scripts/runTest.ts",
    "tsc": "npx tsc --noemit"
  },
  "devDependencies": {
    "@pkg/shared": "*",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/sinon-express-mock": "^1.3.12",
    "@types/sqlite3": "^3.1.11",
    "dotenv": "^16.6.1",
    "sinon-express-mock": "^2.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  },
  "dependencies": {
    "@auth/express": "^0.12.1",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "sqlite3": "^5.1.7"
  }
}
