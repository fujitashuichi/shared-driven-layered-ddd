{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "functions": {
    "packages/backend/dist/main.js": {
      "includeFiles": ["packages/backend/generated/prisma/**"]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://project-nest-server.vercel.app/:path*"
    }
  ]
}
